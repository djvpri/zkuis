GEMINI_API_KEY=your_gemini_api_key_here

# Database Postgres (soal tersimpan + riwayat hasil per user).
# Buat tabel sekali: `npm run db:push`
DATABASE_URL=postgresql://user:pass@host:5432/zkuis

# SSO ekosistem Zomet (login lewat Z One)
CROSS_APP_SECRET=samakan_dengan_Z_One
NEXT_PUBLIC_ZONE_URL=https://zone.zomet.my.id
