GEMINI_API_KEY=your_gemini_api_key_here

# Database Postgres (soal tersimpan + riwayat hasil per user).
# Tabel dibuat OTOMATIS saat start (start = `prisma db push && next start`).
# Manual: `npm run db:push`.
DATABASE_URL=${{Postgres.DATABASE_URL}}

# SSO ekosistem Zomet (login lewat Z One)
CROSS_APP_SECRET=samakan_dengan_Z_One
NEXT_PUBLIC_ZONE_URL=https://zone.zomet.my.id
# Opsional: paksa origin publik untuk redirect /sso (kalau di belakang proxy)
# NEXT_PUBLIC_APP_URL=https://zkuis.zomet.my.id
