generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Soal tersimpan milik satu user (dikaitkan ke email dari SSO Z One).
model SavedQuiz {
  id        String   @id @default(cuid())
  userEmail String
  topik     String
  kategori  String   @default("")
  jumlah    Int      @default(0)
  tipe      String   @default("pilihan_ganda")
  level     String   @default("sedang")
  soal      Json
  bestScore Int?
  shared    Boolean  @default(false) // true = bisa dibuka publik lewat /share/[id]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  attempts       QuizAttempt[]
  publicAttempts PublicAttempt[]

  @@index([userEmail])
}

// Bank soal publik — CPNS/SKD dan ujian nasional lainnya.
// Diisi via seeder (Gemini AI), bisa diakses tanpa login.
model BankSoal {
  id          String   @id @default(cuid())
  kategori    String   // 'TWK' | 'TIU' | 'TKP'
  subKategori String   // 'Pancasila' | 'Verbal' | 'Pelayanan Publik' | dst
  judul       String
  soal        Json     // SoalItem[]
  jumlah      Int
  level       String   @default("sedang")
  createdAt   DateTime @default(now())

  @@index([kategori])
}

// Riwayat pengerjaan kuis (skor per attempt) — untuk statistik/progress.
model QuizAttempt {
  id          String     @id @default(cuid())
  userEmail   String
  savedQuizId String?
  savedQuiz   SavedQuiz? @relation(fields: [savedQuizId], references: [id], onDelete: SetNull)
  topik       String     @default("")
  score       Int
  total       Int
  durasiDetik Int?
  createdAt   DateTime   @default(now())

  @@index([userEmail])
}

// Attempt publik dari kuis yang dibagikan (tanpa login).
model PublicAttempt {
  id        String    @id @default(cuid())
  savedId   String
  saved     SavedQuiz @relation(fields: [savedId], references: [id], onDelete: Cascade)
  nama      String
  skor      Int
  total     Int
  durasi    Int?
  createdAt DateTime  @default(now())

  @@index([savedId, skor(sort: Desc)])
}
